{
    "name": "school/library-admin",
    "description": "智慧图书管理系统 - ThinkPHP6 课程设计",
    "type": "project",
    "keywords": [
        "thinkphp",
        "library"
    ],
    "homepage": "https://www.thinkphp.cn/",
    "license": "Apache-2.0",
    "require": {
        "php": ">=7.2.5",
        "topthink/framework": "^6.1.0",
        "topthink/think-orm": "^2.0",
        "topthink/think-view": "^1.0"
    },
    "require-dev": {
        "symfony/var-dumper": "^4.2"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app"
        },
        "psr-0": {
            "": "extend/"
        }
    },
    "config": {
        "preferred-install": "dist"
    },
    "scripts": {
        "post-autoload-dump": [
            "@php think service:discover",
            "@php think vendor:publish"
        ]
    }
}
